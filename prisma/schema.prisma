generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN
  ADMIN
  SELLER
  HR
  TECHNICIAN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PENDING_PAYMENT
  EXPIRED
  PROSPECT
}

enum ClientType {
  B2B
  B2C
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum NoteType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  CHAT
}

enum ActivityAction {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_DELETED
  STATUS_CHANGED
  SALE_REGISTERED
  DOCUMENT_UPLOADED
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

enum RecipientStatus {
  pending
  sent
  failed
  bounced
  spam
}

enum DealStage {
  LEAD
  CONTACTADO
  PROPUESTA
  NEGOCIACION
  GANADO
  PERDIDO
}

enum TaskStatus {
  PENDIENTE
  EN_CURSO
  HECHA
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum TicketStatus {
  ABIERTO
  EN_PROCESO
  ESPERANDO
  RESUELTO
  CERRADO
}

enum TicketCategory {
  SOPORTE
  BUG
  FACTURACION
  CONSULTA
}

enum EmpresaNotaTipo {
  NOTA
  LLAMADA
  REUNION
  CHAT
  ENVIO_COTIZACION
  CONVERSACION
  SOPORTE
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum CotizacionStatus {
  GUARDADA
  ENVIADA
  ACEPTADA
  RECHAZADA
  VENCIDA
}

enum SmtpProvider {
  SMTP
  SES
}

// ─── Multi-tenant White-label organizations ────────────────────────────────
model Organization {
  id             String   @id @default(cuid())
  name           String
  logoUrl        String?
  primaryColor   String   @default("#6366f1")
  secondaryColor String   @default("#8b5cf6")
  domain         String?  @unique
  crmName        String   @default("CRM Pro")
  quoteValidityDays Int   @default(30)
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPass       String?
  smtpFrom       String?
  smtpProvider   SmtpProvider @default(SMTP)
  sesRegion      String?
  sesAccessKeyId String?
  sesSecretKey   String?
  sesFrom        String?
  sesConfigSet   String?
  // Datos de facturación
  billingAddress      String?
  billingEmail        String?
  billingPhone        String?
  billingTaxId        String?
  paymentInstructions String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          User[]
  clients        Client[]
  plugins        PluginConfig[]
  emailCampaigns EmailCampaign[]
  emailTemplates EmailTemplate[]
  services       Service[]
  products       Product[]
  events         Event[]
  folders        Folder[]
  documents      Document[]
  deals          Deal[]
  tasks          Task[]
  tickets        Ticket[]
  empresas          Empresa[]
  directorioContactos DirectorioContacto[]
  empresaNotas      EmpresaNota[]
  cotizaciones      Cotizacion[]
  asistencias       Asistencia[]
}

// ─── Users & Auth ──────────────────────────────────────────────────────────
model User {
  id                  String   @id @default(cuid())
  supabaseId          String?  @unique  // links to Supabase auth.users.id
  email               String   @unique
  name                String
  role                Role       @default(SELLER)
  status              UserStatus @default(ACTIVE)
  onboardingCompleted Boolean  @default(false)
  forcePasswordChange Boolean  @default(false)
  avatarUrl           String?
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])

  notes          Note[]
  activityLogs   ActivityLog[]
  assignedClients Client[]     @relation("SellerClients")
  sales          Sale[]
  uploadedDocs   Document[]
  emailTemplates EmailTemplate[]
  ownedDeals     Deal[]        @relation("DealOwner")
  assignedTasks  Task[]        @relation("TaskAssignee")
  createdTasks   Task[]        @relation("TaskCreator")
  assignedTickets Ticket[]     @relation("TicketAssignee")
  createdTickets  Ticket[]     @relation("TicketCreator")
  ticketMessages  TicketMessage[] @relation("TicketMessageAuthor")
  empresaNotas    EmpresaNota[]
  cotizaciones    Cotizacion[]
  asistencias     Asistencia[]
}

// Session management is now handled by Supabase Auth

// ─── Services catalog ──────────────────────────────────────────────────────
model Service {
  id             String   @id @default(cuid())
  name           String
  description    String?
  price          Float    @default(0)
  currency       String   @default("USD")
  billingCycle   BillingCycle @default(MONTHLY)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clients        Client[]
  sales          Sale[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// ─── Clients ───────────────────────────────────────────────────────────────
model Client {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String?
  company        String?
  country        String?
  city           String?
  address        String?
  postalCode     String?
  province       String?
  website        String?
  status         ClientStatus @default(ACTIVE)
  isEnabled      Boolean      @default(true)
  clientType     ClientType   @default(B2B)
  serviceType    String?
  tags           String   @default("[]")
  mrr            Float    @default(0)
  contractStart  DateTime?
  contractEnd    DateTime?
  serviceId      String?
  service        Service?  @relation(fields: [serviceId], references: [id])
  // Licencia
  licenseSerial      String?
  licenseVersion     String?
  maxWorkstations    Int?
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  licenseHibernated  Boolean  @default(false)
  licenseRepurchased Boolean  @default(false)
  isActive24x7       Boolean  @default(false)
  // Comercial
  distributorName  String?
  totalInvestment  Float?
  renewalCount     Int      @default(0)
  assignedSellerId String?
  assignedSeller   User?    @relation("SellerClients", fields: [assignedSellerId], references: [id])
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invoices     Invoice[]
  notes        Note[]
  activityLogs ActivityLog[]
  contacts     Contact[]
  sales        Sale[]
  documents    Document[]
  deals        Deal[]
  tasks        Task[]
  tickets      Ticket[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
  @@index([clientType])
  @@index([assignedSellerId])
  @@index([serviceId])
}

model Contact {
  id        String  @id @default(cuid())
  name      String
  email     String?
  phone     String?
  whatsapp  String?
  role      String?
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([clientId])
}

// ─── Invoices ──────────────────────────────────────────────────────────────
model Invoice {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String
  amount         Float
  currency       String   @default("USD")
  status         InvoiceStatus @default(PENDING)
  description    String?
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

// ─── Timeline Notes ────────────────────────────────────────────────────────
model Note {
  id        String   @id @default(cuid())
  content   String
  type      NoteType @default(NOTE)
  metadata  String?  // JSON: { estimatedHours?, estimatedMinutes?, complexity?, estimatedCost?, imageUrl? }
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

// ─── Activity Log ──────────────────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      ActivityAction @default(NOTE)
  description String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([clientId, createdAt])
}

// ─── Sales ─────────────────────────────────────────────────────────────────
model Sale {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  serviceId  String?
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  amount     Float
  currency   String   @default("USD")
  closedAt   DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())

  @@index([sellerId])
  @@index([clientId])
}

// ─── Plugin System ─────────────────────────────────────────────────────────
model PluginConfig {
  id             String   @id @default(cuid())
  pluginId       String
  enabled        Boolean  @default(false)
  config         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt      DateTime @updatedAt

  @@unique([pluginId, organizationId])
}

// ─── Communications ────────────────────────────────────────────────────────
model EmailCampaign {
  id             String   @id @default(cuid())
  name           String
  subject        String
  body           String
  status         CampaignStatus @default(DRAFT)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Tracking aggregates (populated by SES webhooks)
  totalDelivered Int      @default(0)
  totalBounced   Int      @default(0)
  totalSpam      Int      @default(0)
  totalOpened    Int      @default(0)

  recipients CampaignRecipient[]
}

model CampaignRecipient {
  id            String        @id @default(cuid())
  campaignId    String
  campaign      EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email         String
  name          String?
  status        RecipientStatus @default(pending)
  sentAt        DateTime?
  error         String?
  // SES tracking fields
  messageId     String?
  deliveredAt   DateTime?
  bouncedAt     DateTime?
  bounceType    String?
  bounceSubType String?
  spamAt        DateTime?
  openedAt      DateTime?
  openCount     Int           @default(0)
}

// ─── Email Templates ───────────────────────────────────────────────────────
model EmailTemplate {
  id             String   @id @default(cuid())
  name           String
  subject        String
  body           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Events ────────────────────────────────────────────────────────────────
model Event {
  id             String   @id @default(cuid())
  name           String
  description    String?
  eventDate      DateTime?
  location       String?
  isActive       Boolean  @default(true)
  webhookSecret  String   @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  attendees EventAttendee[]

  @@index([organizationId])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  company   String?
  phone     String?
  country   String?
  email     String?
  source    String   @default("manual")
  createdAt DateTime @default(now())

  @@index([eventId])
}

// ─── Document Repository ───────────────────────────────────────────────────
model Folder {
  id             String   @id @default(cuid())
  name           String
  parentId       String?
  parent         Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children       Folder[] @relation("FolderTree")
  clientId       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents      Document[]
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

model Document {
  id             String   @id @default(cuid())
  name           String
  originalName   String
  mimeType       String
  size           Int
  url            String
  folderId       String?
  folder         Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tags           String   @default("[]")
  uploadedById   String
  uploadedBy     User     @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([clientId])
}

// ─── Sales Pipeline ────────────────────────────────────────────────────────
model Deal {
  id                String    @id @default(cuid())
  title             String
  amount            Float     @default(0)
  currency          String    @default("USD")
  probability       Int       @default(0)
  stage             DealStage @default(LEAD)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  notes             String?
  clientId          String?
  client            Client?   @relation(fields: [clientId], references: [id])
  empresaId         String?
  empresa           Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  ownerId           String
  owner             User      @relation("DealOwner", fields: [ownerId], references: [id])
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([organizationId, stage])
  @@index([ownerId])
}

// ─── Tasks ─────────────────────────────────────────────────────────────────
model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus @default(PENDIENTE)
  priority       Priority   @default(MEDIA)
  dueDate        DateTime?
  completedAt    DateTime?
  viewedAt       DateTime?
  assignedToId   String
  assignedTo     User      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User      @relation("TaskCreator", fields: [createdById], references: [id])
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id])
  empresaId      String?
  empresa        Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([empresaId])
}

// ─── Support Tickets ───────────────────────────────────────────────────────
model Ticket {
  id             String    @id @default(cuid())
  number         Int
  title          String
  description    String
  status         TicketStatus   @default(ABIERTO)
  priority       Priority       @default(MEDIA)
  category       TicketCategory @default(SOPORTE)
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id])
  empresaId      String?
  empresa        Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     User?     @relation("TicketAssignee", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User      @relation("TicketCreator", fields: [createdById], references: [id])
  resolvedAt     DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       TicketMessage[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([number, organizationId])
  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([clientId])
  @@index([empresaId])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content    String
  isInternal Boolean  @default(false)
  userId     String
  user       User     @relation("TicketMessageAuthor", fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

// ─── Directorio de Empresas y Técnicos ────────────────────────────────────
model Empresa {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isCliente      Boolean  @default(false)
  clienteDesde   DateTime?
  activity       String?
  address        String?
  codigoPostal   String?
  city           String?
  province       String?
  country        String?
  website        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contactos      DirectorioContacto[]
  notas          EmpresaNota[]
  cotizaciones   Cotizacion[]
  deals          Deal[]
  tasks          Task[]
  tickets        Ticket[]

  @@index([organizationId])
  @@index([organizationId, name])
}

model DirectorioContacto {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  companyRaw     String?
  role           String?
  email          String?
  phone          String?
  empresaId      String?
  empresa        Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([empresaId])
  @@index([email])
}

// ─── Actividad / Notas de Empresa ─────────────────────────────────────────
model EmpresaNota {
  id               String   @id @default(cuid())
  empresaId        String
  empresa          Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  tipo             EmpresaNotaTipo @default(NOTA)
  content          String
  estimatedMinutes Int      @default(0)
  metadata         String?  // JSON: { imageUrl? }
  createdAt        DateTime @default(now())

  @@index([empresaId])
  @@index([organizationId])
}

// ─── Catálogo de Productos (venta única) ──────────────────────────────────
model Product {
  id             String   @id @default(cuid())
  name           String
  description    String?
  price          Float    @default(0)
  currency       String   @default("USD")
  unit           String   @default("unidad")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// ─── Historial de Cotizaciones ────────────────────────────────────────────
model Cotizacion {
  id             String    @id @default(cuid())
  ref            String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  empresaId      String?
  empresa        Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  recipientEmail String
  recipientName  String
  items          Json
  total          Float
  discount       Float     @default(0)
  finalTotal     Float     @default(0)
  currency       String    @default("USD")
  notes          String?
  validityDays   Int       @default(30)
  status         CotizacionStatus @default(ENVIADA)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([empresaId])
  @@index([userId])
}

// ─── Módulo RRHH: Asistencia ──────────────────────────────────────────────
model Asistencia {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fecha          DateTime  @db.Date
  horaEntrada    DateTime?
  horaSalida     DateTime?
  ausente        Boolean   @default(false)
  tardanza       Boolean   @default(false)
  observaciones  String?
  creadoPorId    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, fecha, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([fecha])
}
