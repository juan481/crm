# ─── Base de datos Supabase ────────────────────────────────────────────
# Ambas URLs las encontrás en: Supabase → tu proyecto → Settings → Database → Connection string
# DATABASE_URL = "Transaction pooler" (usada por Prisma en producción)
# DIRECT_URL   = "Direct connection" (usada por prisma db push / migrate)
DATABASE_URL="postgresql://postgres.XXXX:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.XXXX:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase Auth & Storage ─────────────────────────────────────────────
# Encontrás estas claves en: Supabase → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://XXXX.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJh..."
# ¡IMPORTANTE! Sin esta clave no funcionan: subida de logo, documentos, ni crear usuarios
SUPABASE_SERVICE_ROLE_KEY="eyJh..."

# ─── Supabase Storage ────────────────────────────────────────────────────
# Nombre del bucket en Supabase Storage (crealo si no existe, con acceso público)
SUPABASE_STORAGE_BUCKET="uploads"

# ─── Seguridad ────────────────────────────────────────────────────────
JWT_SECRET="tu-secreto-super-largo-cambiar-en-produccion"
JWT_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tu-crm.vercel.app"
APP_NAME="CRM Pro"

# ─── Email SMTP (opcional, para envío de mails) ───────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CRM Pro <noreply@tucrm.com>"
